{
  "name": "Hello Happy Backend",
  "dockerComposeFile": "../../compose.dev.yml",
  "service": "backend",
  "runServices": ["db", "backend"],
  "workspaceFolder": "/workspaces/hello-happy",
  "remoteUser": "root",
  "forwardPorts": [8080, 5433],
  "shutdownAction": "none",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot"
      ]
    }
  }
}
